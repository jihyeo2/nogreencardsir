{
  "manifest_version": 3,
  "name": "LinkedIn Job Filter Extension",
  "version": "1.0",
  "description": "Flags jobs with citizenship or sponsorship restrictions",
  "icons": {
    "16": "icons/somecard.png",
    "32": "icons/somecard.png",
    "48": "icons/somecard.png",
    "128": "icons/somecard.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": [ "src/content.js" ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://*/*",
    "https://*/*"
  ]
}